{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moltendb-docs",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "main": "./dist/server/server.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/browser"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
